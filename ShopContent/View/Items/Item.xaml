<UserControl x:Class="ShopContent.View.Items.Item"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ShopContent.View.Items"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             HorizontalAlignment="Stretch" Margin="5">
    <UserControl.Resources>
        <Style TargetType="Button" x:Key="Update">
            <Setter Property="Background" Value="#FF4FC318"/>
            <Setter Property="BorderBrush" Value="#FF4FC318"/>
            <Setter Property="Foreground" Value="white"/>
        </Style>
        <Style TargetType="Button" x:Key="Delete">
            <Setter Property="Background" Value="#FFC34E18"/>
            <Setter Property="BorderBrush" Value="#FFC34E18"/>
            <Setter Property="Foreground" Value="white"/>
        </Style>
    </UserControl.Resources>
    
    <Grid Background="white">
        <Grid.Effect>
            <DropShadowEffect Direction="270" BlurRadius="5" ShadowDepth="2" Opacity="0.5"/>
        </Grid.Effect>

        <Image Height="50" Width="50" VerticalAlignment="top" HorizontalAlignment="Left" Margin="10" Source="/Images/ic-item.png"/>
        <Button Style="{StaticResource Update}" Content="Изменить" Width="55" Height="25" VerticalAlignment="top" HorizontalAlignment="left" Margin="10,75,0,0" Command="{Binding OnEdit}" FontSize="10">
            <Button.Effect>
                <DropShadowEffect Direction="270" BlurRadius="5" ShadowDepth="2" Opacity="0.5"/>
            </Button.Effect>
        </Button>
        <Button Style="{StaticResource Delete}" Content="Удалить" Width="55" Height="25" VerticalAlignment="top" HorizontalAlignment="left" Margin="10,105,0,0" Command="{Binding OnDelete}" FontSize="10">
            <Button.Effect>
                <DropShadowEffect Direction="270" BlurRadius="5" ShadowDepth="2" Opacity="0.5"/>
            </Button.Effect>
        </Button>

        <Grid Margin="65,0,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Label Content="Наименование:" VerticalAlignment="top" Margin="10"/>
            <TextBox Text="{Binding Name}" VerticalAlignment="top" Height="25" Margin="10,36,10,0" VerticalContentAlignment="Center" IsEnabled="False"/>
            <Label Content="Стоимость:" VerticalAlignment="top" Margin="10" Grid.Column="1"/>
            <TextBox Text="{Binding Price}" VerticalAlignment="top" Height="25" Margin="10,36,10,0" VerticalContentAlignment="Center" Grid.Column="1" IsEnabled="False"/>
            <Label Content="Категория:" VerticalAlignment="top" Margin="10,67,10,0" Grid.ColumnSpan="2"/>
            <TextBox Text="{Binding Category.Name}" VerticalAlignment="top" Height="25" Margin="10,96,10,0" VerticalContentAlignment="Center" Grid.ColumnSpan="2" IsEnabled="False"/>
            <Label Content="Описание:" VerticalAlignment="top" Margin="10,123,10,0" Grid.ColumnSpan="2"/>
            <TextBox Text="{Binding Description}" VerticalAlignment="top" Height="25" Margin="10,150,10,0" VerticalContentAlignment="Center" Grid.ColumnSpan="2" IsEnabled="False"/>
        </Grid>
    </Grid>
</UserControl>
